    "title": "Open 'Home creations' via Global Search",
    "priority": "P1",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "step-open-home",
        "action": "openUrl",
        "targetDescription": "Navigate to Salesforce Home",
        "value": "/lightning/page/home"
      },
      {
        "id": "step-open-global-search",
        "action": "tap",
        "targetDescription": "Open global search",
        "screenName": "HomePage",
        "pageObjectMethod": "clickSearch"
      },
      {
        "id": "step-global-search-visible",
