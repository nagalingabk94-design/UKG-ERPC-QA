        "targetDescription": "Verify global search is visible",
        "screenName": "HomePage",
        "pageObjectMethod": "expectSearchVisible"
      },
      {
        "id": "step-type-query",
        "action": "typeText",
        "targetDescription": "Type 'Home creations' and submit in global search",
        "locatorHint": "role=combobox[name=\"Search...\"]",
        "value": "Home creations{Enter}"
      },
      {
        "id": "step-wait-results",
        "action": "wait",
        "targetDescription": "Wait for search results to load",
        "value": "2000"
      },
      {
        "id": "step-open-result",
        "action": "tap",
        "targetDescription": "Open 'Home creations' from search results",
        "locatorHint": "role=link[name=\"Home creations\"]"
